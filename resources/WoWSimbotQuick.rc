IDD_FORMVIEW_RESULTS DIALOGEX 0, 0, 600, 250
STYLE DS_SETFONT | WS_CHILD | WS_VISIBLE
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
