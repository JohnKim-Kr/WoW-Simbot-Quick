    CONTROL         "Augment",IDC_CHECK_AUGMENT,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,165,112,45,10
    CONTROL         "Bloodlust",IDC_CHECK_BLOODLUST,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,25,127,50,10
    CONTROL         "Potion",IDC_CHECK_POTION,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,85,127,40,10
